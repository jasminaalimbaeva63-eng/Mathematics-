const sidebar = document.getElementById('lessonSidebar');
const doneLessons = new Set();
let currentLesson = null;

CURRICULUM.forEach(topic => {
  const label = document.createElement('div');
  label.style.cssText='font-family:var(--mono);font-size:.68rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);padding:.8rem .5rem .3rem;margin-top:.5rem';
  label.textContent=topic.title;
  sidebar.appendChild(label);

  topic.lessons.forEach(lesson => {
    const item = document.createElement('div');
    item.className='lesson-item';
    item.id='si-'+lesson.id;
    item.innerHTML=`<div class="li-dot"></div>${lesson.title}`;
    item.addEventListener('click',()=>loadLesson(lesson.id));
    sidebar.appendChild(item);
  });
});

function loadLesson(id) {
  currentLesson = null;
  CURRICULUM.forEach(t=>t.lessons.forEach(l=>{if(l.id===id) currentLesson=l}));
  if(!currentLesson) return;

  document.querySelectorAll('.lesson-item').forEach(el=>el.classList.remove('active'));
  document.getElementById('si-'+id)?.classList.add('active');

  const topic = CURRICULUM.find(t=>t.lessons.some(l=>l.id===id));
  const idx = topic.lessons.findIndex(l=>l.id===id);
  const prevId = idx>0 ? topic.lessons[idx-1].id : null;
  const nextId = idx<topic.lessons.length-1 ? topic.lessons[idx+1].id : null;

  const ex = currentLesson.exercise;
  let exerciseHTML='';
  if(ex.type==='choice'){
    exerciseHTML=`<div class="exercise-box">
      <div style="font-family:var(--mono);font-size:.72rem;letter-spacing:2px;color:var(--teal);text-transform:uppercase;margin-bottom:.8rem">// задание</div>
      <div class="ex-q">${ex.q}</div>
      <div class="ex-opts">${ex.opts.map((o,i)=>`<button class="ex-opt" onclick="checkChoice(this,${i},${ex.ans},'${ex.hint}')">${o}</button>`).join('')}</div>
      <div class="ex-feedback" id="ex-fb"></div>
    </div>`;
  } else {
    exerciseHTML=`<div class="exercise-box">
      <div style="font-family:var(--mono);font-size:.72rem;letter-spacing:2px;color:var(--teal);text-transform:uppercase;margin-bottom:.8rem">// задание</div>
      <div class="ex-q">${ex.q}</div>
      <input class="ex-input" id="ex-inp" placeholder="Ваш ответ..." onkeydown="if(event.key==='Enter')checkInput('${ex.ans}','${ex.hint}')"/>
      <div style="margin-top:.6rem"><button class="btn btn-outline" style="padding:.55rem 1.2rem;font-size:.85rem" onclick="checkInput('${ex.ans}','${ex.hint}')">Проверить</button></div>
      <div class="ex-feedback" id="ex-fb"></div>
    </div>`;
  }

  document.getElementById('lessonContent').innerHTML=`
    <div class="lesson-tag">${topic.title}</div>
    <div class="lesson-title">${currentLesson.title}</div>
    <div class="lesson-body">${currentLesson.body}</div>
    ${exerciseHTML}
    <div class="lesson-nav">
      ${prevId?`<button class="btn btn-outline" onclick="loadLesson('${prevId}')">← Назад</button>`:'<div></div>'}
      ${nextId?`<button class="btn btn-gold" onclick="doneMark('${id}');loadLesson('${nextId}')">Следующий урок →</button>`:`<button class="btn btn-gold" onclick="doneMark('${id}');showPage('test')">Пройти тест →</button>`}
    </div>`;
}

function doneMark(id){
  doneLessons.add(id);
  const el=document.getElementById('si-'+id);
  if(el){el.classList.add('done');el.classList.remove('active')}
}
function checkChoice(btn,idx,ans,hint){
  if(btn.parentElement.querySelector('.correct,.wrong')) return;
  if(idx===ans){btn.classList.add('correct');setFb(true,'Правильно! ✓')}
  else{btn.classList.add('wrong');btn.parentElement.children[ans].classList.add('correct');setFb(false,'Неверно. Подсказка: '+hint)}
}
function checkInput(ans,hint){
  const v=document.getElementById('ex-inp')?.value.trim();
  if(!v) return;
  if(v===ans){setFb(true,'Правильно! ✓')}
  else{setFb(false,`Неверно. Правильный ответ: ${ans}. ${hint}`)}
}
function setFb(ok,msg){
  const fb=document.getElementById('ex-fb');
  if(fb){fb.style.color=ok?'var(--teal)':'var(--rose)';fb.textContent=msg}
}

/* ══════════════════════════════════════════
   TEST
══════════════════════════════════════════ */
let tIdx=0, tScore=0, tAnswered=false;

function renderTest(){
  const fill=document.getElementById('testFill');
  const content=document.getElementById('testContent');
  fill.style.width=(tIdx/TEST_QS.length*100)+'%';

  if(tIdx>=TEST_QS.length){
    const pct=Math.round(tScore/TEST_QS.length*100);
    const emoji=pct>=80?'🏆':pct>=60?'👍':'💪';
    const msg=pct>=80?'Отличный результат!':pct>=60?'Хороший результат!':'Продолжайте учиться!';
    content.innerHTML=`<div class="test-score-board">
      <div class="score-circle"><div class="score-num">${pct}%</div><div class="score-label">${tScore}/${TEST_QS.length}</div></div>
      <div class="score-text">${emoji} ${msg}</div>
      <div class="score-sub">Правильных ответов: ${tScore} из ${TEST_QS.length}</div>
      <button class="btn btn-gold" onclick="tIdx=0;tScore=0;renderTest()">↺ Пройти снова</button>
      <button class="btn btn-outline" style="margin-left:.8rem" onclick="showPage('lessons')">📖 К урокам</button>
    </div>`;
    return;
  }

  const q=TEST_QS[tIdx]; tAnswered=false;
  content.innerHTML=`
    <div class="test-card">
      <div class="test-qnum">Вопрос ${tIdx+1} из ${TEST_QS.length}</div>
      <div class="test-q">${q.q}</div>
      <div class="test-opts">${q.opts.map((o,i)=>`
        <button class="test-opt" id="to-${i}" onclick="pickTest(${i},${q.ans})">
          <span class="opt-letter">${['A','B','C','D'][i]}</span>${o}
        </button>`).join('')}
      </div>
      <div class="test-actions">
        <div style="font-family:var(--mono);font-size:.8rem;color:var(--muted)">Счёт: ${tScore}</div>
        <button class="btn btn-outline" id="nextBtn" style="display:none" onclick="tIdx++;renderTest()">Следующий →</button>
      </div>
    </div>`;
}

function pickTest(idx,ans){
  if(tAnswered) return; tAnswered=true;
  for(let i=0;i<4;i++) document.getElementById('to-'+i)?.classList.add(i===ans?'correct':i===idx&&idx!==ans?'wrong':'');
  if(idx===ans) tScore++;
  document.getElementById('nextBtn').style.display='inline-flex';
}
renderTest();

