        max_tokens:1000,
        system:`Ты дружелюбный учитель математики. Отвечай по-русски. 
Объясняй ясно, по шагам. Используй примеры. Выделяй формулы жирным.
Используй HTML-теги: <strong> для важного, <code> для формул и чисел.
Если задача — покажи решение по шагам. Отвечай кратко (максимум 300 слов).`,
        messages:[{role:'user',content:text}]
      })
    });
    const data=await resp.json();
    const answer=(data.content||[]).filter(b=>b.type==='text').map(b=>b.text).join('');
    typing.innerHTML=formatAI(answer);
  }catch(e){
    typing.innerHTML='<span style="color:var(--rose)">Ошибка соединения. Попробуйте ещё раз.</span>';
  }
  sendBtn.disabled=false;
  document.getElementById('chatWindow').scrollTop=9999;
}

function escHtml(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function formatAI(t){
  // Basic markdown-ish formatting
  return t
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/\n\n/g,'</p><p>')
    .replace(/\n/g,'<br/>')
    .replace(/^/,'<p>').replace(/$/,'</p>');
}

/* ── Show first lesson by default ── */
loadLesson(CURRICULUM[0].lessons[0].id);
</script>
